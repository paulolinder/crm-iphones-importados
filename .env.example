# ===============================
# Eleve Imports CRM - Environment Variables
# ===============================
# Copy this file to .env and fill in the values
# NEVER commit .env to version control
# ===============================

# ===============================
# Application
# ===============================
NODE_ENV=development
APP_URL=http://localhost:3000

# ===============================
# Nuxt
# ===============================
NUXT_PUBLIC_APP_NAME="Eleve Imports CRM"
NUXT_PUBLIC_APP_VERSION="0.1.0"

# Landing pública (site comercial)
# Número só dígitos, com DDI 55 — ex.: 5565991234567
NUXT_PUBLIC_WHATSAPP_PHONE=
# Mensagem pré-preenchida opcional no WhatsApp
# NUXT_PUBLIC_WHATSAPP_MESSAGE="Olá! Vim pelo site da Eleve Imports."

# ===============================
# Supabase - Public (exposed to frontend)
# ===============================
# Get these from: https://supabase.com/dashboard/project/migxevookiubncmcsgvy/settings/api
NUXT_PUBLIC_SUPABASE_URL=https://migxevookiubncmcsgvy.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-supabase-anon-key

# ===============================
# Supabase - Private (server-side only)
# ===============================
# WARNING: Keep this secret! Never expose to frontend
SUPABASE_SERVICE_KEY=your-supabase-service-role-key

# ===============================
# Production Settings
# ===============================
# Host and port for production server
HOST=0.0.0.0
PORT=3000
NITRO_PORT=3000
NITRO_HOST=0.0.0.0
